<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) data-extraction / device-transfer policy.
    Same posture as backup_rules.xml: nothing leaves this device by default.

    If the user later opts in to on-device memory export, that goes through
    MemoryExporter + UIActivityViewController-equivalent share flow, NEVER
    through the system's auto-transfer path.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
